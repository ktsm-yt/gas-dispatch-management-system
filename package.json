{
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "env:init": "node tools/init-env.js",
    "env:check": "node tools/env-check.js",
    "env:fill": "python3 tools/fill-env-from-docx.py",
    "env:fill:templates": "node tools/fill-env-from-billing-templates.js",
    "render:docs": "node tools/render-docs.js",
    "hooks:install": "bash scripts/install-hooks.sh",
    "e2e:chrome": "open -na 'Google Chrome' --args --remote-debugging-port=9222 --user-data-dir=\"$HOME/Dev/DevProject/gas-dispatch-system/e2e/auth/chrome-debug-profile\"",
    "e2e:connect": "npx tsx e2e/scripts/screenshot-connect.ts",
    "build": "bash scripts/build-gas.sh",
    "gas:push": "npm run build && cd app/gas && npx clasp push",
    "gas:status": "bash scripts/clasp-env-status.sh",
    "gas:deploy": "bash scripts/deploy-prod.sh",
    "typecheck": "bash scripts/with-stripped-exports.sh npx tsc -p app/gas/tsconfig.json --noEmit",
    "lint": "eslint app/gas/src/ --ext .js,.gs,.ts",
    "lint:fix": "eslint app/gas/src/ --ext .js,.gs,.ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/google-apps-script": "1.0.83",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "eslint": "8.56.0",
    "tsx": "^4.21.0",
    "typescript": "5.3.3",
    "vitest": "3.2.1",
    "xlsx": "^0.18.5"
  }
}
