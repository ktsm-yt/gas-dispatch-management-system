{
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "env:init": "node tools/init-env.js",
    "env:check": "node tools/env-check.js",
    "env:fill": "python3 tools/fill-env-from-docx.py",
    "env:fill:templates": "node tools/fill-env-from-billing-templates.js",
    "render:docs": "node tools/render-docs.js",
    "hooks:install": "bash scripts/install-hooks.sh",
    "e2e:chrome": "open -na 'Google Chrome' --args --remote-debugging-port=9222 --user-data-dir=\"$HOME/Dev/DevProject/gas-dispatch-system/e2e/auth/chrome-debug-profile\"",
    "e2e:connect": "npx tsx e2e/scripts/screenshot-connect.ts",
    "gas:push": "cd app/gas && npx clasp push",
    "gas:deploy": "bash scripts/deploy-prod.sh",
    "typecheck": "tsc -p app/gas/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/google-apps-script": "1.0.83",
    "tsx": "^4.21.0",
    "typescript": "5.3.3",
    "xlsx": "^0.18.5"
  }
}
