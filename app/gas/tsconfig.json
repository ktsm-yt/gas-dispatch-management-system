{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "types": ["google-apps-script"],
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["src/tests/**/*", "dist"]
}
