{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist/src",
    "module": "None",
    "declaration": false,
    "sourceMap": false,
    "removeComments": false
  },
  "include": ["src/**/*.ts", "src/types/**/*.d.ts"],
  "exclude": ["src/tests/**/*", "dist"]
}
