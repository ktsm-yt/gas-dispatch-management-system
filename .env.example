# ==============================================================================
# 環境変数テンプレート
# ==============================================================================
# このファイルを `.env` にコピーして実際の値を設定してください。
# `.env` は .gitignore に含まれており、リポジトリにコミットされません。
#
# Copy this file to `.env` and fill in actual values.
# `.env` is gitignored and will not be committed.
# ==============================================================================

# ------------------------------------------------------------------------------
# 自社情報 (Company Information)
# ------------------------------------------------------------------------------
# 請求書・帳票に出力される自社情報

COMPANY_NAME="株式会社サンプル"
COMPANY_NAME_SHORT="サンプル"
POSTAL_CODE="〒100-0001"
ADDRESS="東京都千代田区千代田1-1-1 サンプルビル101"
TEL="03-0000-0000"
FAX="03-0000-0001"

# インボイス登録番号 (適格請求書発行事業者登録番号)
INVOICE_REGISTRATION_NUMBER="T0000000000000"

# ------------------------------------------------------------------------------
# 銀行口座情報 (Bank Account)
# ------------------------------------------------------------------------------
BANK_NAME="サンプル銀行"
BRANCH_NAME="本店（001）"
ACCOUNT_NUMBER="（普）0000000"
ACCOUNT_HOLDER="サンプル（カ"

# ------------------------------------------------------------------------------
# Google Workspace / 運用情報 (Operations)
# ------------------------------------------------------------------------------
WORKSPACE_DOMAIN="example.com"

# 管理者情報
CEO_NAME="山田"
CEO_EMAIL="ceo@example.com"
MANAGER_NAME="鈴木"
MANAGER_EMAIL="manager@example.com"

# 通知先（代表管理者・ドキュメント用）
ADMIN_EMAIL="admin@example.com"

# 変更要求（CR）ログのURL（ドキュメント用）
CR_LOG_SPREADSHEET_URL="https://docs.google.com/spreadsheets/d/xxxxxxxxxxxxxxxxxxxx/edit#gid=0"

# ------------------------------------------------------------------------------
# プロジェクト設定 (Project Settings)
# ------------------------------------------------------------------------------
PROJECT_NAME="sample-dispatch"

# ------------------------------------------------------------------------------
# 規模・見積り（ドキュメント用 / GitHub公開向けに匿名化）
# ------------------------------------------------------------------------------
DAILY_JOB_COUNT_RANGE="X〜Y件"
MONTHLY_JOB_COUNT="約X,XXX件"
ANNUAL_JOB_COUNT="約XX,XXX件"
CUSTOMER_COMPANY_COUNT_RANGE="X〜Y社"
CUSTOMER_MASTER_COUNT="約X,XXX件"
STAFF_MASTER_COUNT="約XX名"
CONCURRENT_USERS="X〜Y名"

MONTHLY_REVENUE="約X,XXX万円"
ANNUAL_REVENUE_RANGE="X〜Y億円"
DAILY_REVENUE_PEAK="XXX万円"
WORK_HOURS_PEAK="X〜Y時間"

PHASE1_COST="XXX,XXX円"
PHASE2_COST="XXX,XXX円"
ADD_PDF_COST="XXX,XXX円"

# ------------------------------------------------------------------------------
# 請求書テンプレート種別名 (Invoice Template Types)
# ------------------------------------------------------------------------------
# 顧客ごとの請求書様式の識別名（実際の顧客名を使用）

FORMAT1_TYPE="顧客A"
FORMAT2_TYPE="顧客B"
FORMAT3_TYPE="顧客C"
ATAMAGAMI_TYPE="顧客D"

# 頭紙サンプルの顧客名
CUSTOMER_NAME="顧客D"

# スタッフ名（テンプレートファイル名に含まれる場合）
STAFF_NAME="担当者"

# アーキテクチャ図URL（GitHub Pages等）
ARCHITECTURE_DIAGRAM_URL="https://example.github.io/project/"

# ------------------------------------------------------------------------------
# Google Apps Script 設定 (GAS Configuration)
# ------------------------------------------------------------------------------
# これらの値は GAS の ScriptProperties に設定します。
# 詳細は docs/05_ops/10_development.md を参照してください。

# GAS_ENV=DEV
# GAS_DB_SPREADSHEET_ID_DEV=xxxxx
# GAS_DB_SPREADSHEET_ID_PROD=xxxxx
# GAS_PDF_FOLDER_ID_DEV=xxxxx
# GAS_PDF_FOLDER_ID_PROD=xxxxx
# GAS_ARCHIVE_FOLDER_ID_DEV=xxxxx
# GAS_ARCHIVE_FOLDER_ID_PROD=xxxxx
# GAS_TEMPLATE_FORMAT1_ID=xxxxx
# GAS_TEMPLATE_FORMAT2_ID=xxxxx
# GAS_TEMPLATE_FORMAT3_ID=xxxxx
# GAS_TEMPLATE_ATAMAGAMI_ID=xxxxx
